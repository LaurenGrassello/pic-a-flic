{
  "name": "pic-a-flic/app",
  "description": "Pic-a-flic \u2014 Slim 4 + Doctrine ORM API skeleton",
  "type": "project",
  "require": {
    "php": "^8.2",
    "slim/slim": "^4.13",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "doctrine/orm": "^2",
    "doctrine/migrations": "^3.6",
    "vlucas/phpdotenv": "^5",
    "monolog/monolog": "^3.6",
    "firebase/php-jwt": "^6.10",
    "symfony/cache": "^7.3",
    "guzzlehttp/guzzle": "^7",
    "php-http/guzzle7-adapter": "^1",
    "nyholm/psr7": "^1",
    "http-interop/http-factory-guzzle": "^1",
    "doctrine/dbal": "^3"
  },
  "autoload": {
    "psr-4": {
      "PicaFlic\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8080 -t public",
    "post-install-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  }
}
